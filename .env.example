# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Public app URL (used by Supabase Edge Functions for Duitku returnUrl)
PUBLIC_SITE_URL=https://invoice.idcashier.com

# Duitku callback URL (Supabase Edge Function). If empty, functions use `${SUPABASE_URL}/functions/v1/duitku-callback`.
DUITKU_CALLBACK_URL=https://your-project-ref.supabase.co/functions/v1/duitku-callback

# Optional: For production builds
VITE_BUILD_MODE=production
