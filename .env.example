# Public client-side config
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
PUBLIC_SITE_URL=https://invoice.idcashier.com
DUITKU_CALLBACK_URL=https://your-project-ref.supabase.co/functions/v1/duitku-callback

# Private/server-only config (put the real values in .env.local, not in git)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_ACCESS_TOKEN=your_supabase_access_token_here
DUITKU_MERCHANT_CODE=your_duitku_merchant_code_here
DUITKU_API_KEY=your_duitku_api_key_here
DUITKU_ENV=production

# Google OAuth is configured in Supabase Auth provider.
# Do not put Google client secrets in frontend env files.
